{
  "kind": "collectionType",
  "collectionName": "visa_requests",
  "info": {
    "singularName": "visa-request",
    "pluralName": "visa-requests",
    "displayName": "VisaRequest"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "medical_case": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::medical-case.medical-case",
      "inversedBy": "visa_requests"
    },
    "country": {
      "type": "string"
    },
    "visaType": {
      "type": "string"
    },
    "status": {
      "type": "enumeration",
      "default": "NOT_STARTED",
      "enum": [
        "NOT_STARTED",
        "DOCS_REQUESTED",
        "DOCS_RECEIVED",
        "INVITATION_PREPARING",
        "INVITATION_SENT",
        "SUBMITTED",
        "APPROVED",
        "REJECTED",
        "NOT_REQUIRED"
      ]
    },
    "requiredDocs": {
      "type": "json"
    },
    "invitationLetter": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "files"
      ]
    },
    "submittedAt": {
      "type": "datetime"
    },
    "approvedAt": {
      "type": "datetime"
    },
    "notes": {
      "type": "text"
    }
  }
}
