{
  "kind": "collectionType",
  "collectionName": "conversations",
  "info": {
    "singularName": "conversation",
    "pluralName": "conversations",
    "displayName": "Conversation"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "users_permissions_users": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user",
      "mappedBy": "conversations"
    },
    "lastMessage": {
      "type": "text"
    },
    "lastMessageAt": {
      "type": "datetime"
    },
    "channel": {
      "type": "enumeration",
      "default": "case",
      "enum": [
        "case",
        "appointment",
        "support"
      ]
    },
    "lifecycleStatus": {
      "type": "enumeration",
      "default": "open",
      "enum": [
        "open",
        "pending",
        "closed"
      ]
    },
    "sharedQueue": {
      "type": "boolean",
      "default": true
    },
    "doctorChatEnabled": {
      "type": "boolean",
      "default": false
    },
    "activeManager": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "takeoverAt": {
      "type": "datetime"
    },
    "lastReadBy": {
      "type": "json"
    },
    "unreadBy": {
      "type": "json"
    },
    "appointment": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::appointment.appointment"
    },
    "medical_case": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::medical-case.medical-case",
      "inversedBy": "conversation"
    },
    "messages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::message.message",
      "mappedBy": "conversation"
    }
  }
}
