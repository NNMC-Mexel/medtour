{
  "kind": "collectionType",
  "collectionName": "medical_documents",
  "info": {
    "singularName": "medical-document",
    "pluralName": "medical-documents",
    "displayName": "MedicalDocument"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "analysis",
        "prescription",
        "certificate",
        "mrt",
        "xray",
        "ultrasound",
        "other"
      ]
    },
    "description": {
      "type": "text"
    },
    "reviewStatus": {
      "type": "enumeration",
      "default": "UPLOADED",
      "enum": [
        "REQUESTED",
        "UPLOADED",
        "IN_REVIEW",
        "APPROVED",
        "REJECTED",
        "TRANSLATION_NEEDED",
        "TRANSLATED"
      ]
    },
    "reviewNotes": {
      "type": "text"
    },
    "requestedLanguage": {
      "type": "string"
    },
    "dueDate": {
      "type": "date"
    },
    "reviewedAt": {
      "type": "datetime"
    },
    "file": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "medical_documents"
    },
    "doctor": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::doctor.doctor",
      "inversedBy": "medical_documents"
    },
    "appointment": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::appointment.appointment",
      "inversedBy": "medical_documents"
    },
    "medical_case": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::medical-case.medical-case",
      "inversedBy": "medical_documents"
    },
    "sharedWithDoctors": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::doctor.doctor"
    },
    "requestedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "reviewedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
