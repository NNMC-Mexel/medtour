{
  "kind": "collectionType",
  "collectionName": "price_items",
  "info": {
    "singularName": "price-item",
    "pluralName": "price-items",
    "displayName": "Price Item",
    "description": "Editable services and prices for the public price list"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "category": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "price": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "currency": {
      "type": "enumeration",
      "enum": ["KZT", "USD", "EUR", "RUB"],
      "default": "KZT",
      "required": true
    },
    "unit": {
      "type": "string",
      "default": "услуга"
    },
    "badge": {
      "type": "string"
    },
    "note": {
      "type": "text"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "i18n": {
      "type": "json"
    },
    "image": {
      "allowedTypes": ["images"],
      "type": "media",
      "multiple": false
    },
    "priceUSD": {
      "type": "decimal",
      "min": 0
    }
  }
}
