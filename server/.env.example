HOST=0.0.0.0
PORT=1340
APP_NAME=MedTour
FRONTEND_URL=http://localhost:5173
SERVER_URL=http://localhost:1340
FRONTEND_URLS=http://localhost:5173,http://localhost:1342
# Production example:
# FRONTEND_URL=https://medtour.nnmc.kz
# SERVER_URL=https://medtourserver.nnmc.kz
# FRONTEND_URLS=https://medtour.nnmc.kz,https://www.medtour.nnmc.kz,https://medtourserver.nnmc.kz,https://medtoursignaling.nnmc.kz
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified
# PII encryption-at-rest for iin/passportNumber (RK Law 94-V art.10).
# REQUIRED in production — the server refuses to boot without a valid 32-byte key.
# Generate with: openssl rand -hex 32  — 32 bytes as hex or base64.
# Keep separate from the database; losing it makes encrypted PII unrecoverable.
PII_ENCRYPTION_KEY=tobemodified

# Local default is SQLite. Production should use Postgres with DATABASE_URL.
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
CRON_ENABLED=true
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgres://user:password@host:5432/medtour
# DATABASE_SSL=false

# SMTP for password reset and email confirmation.
# For Yandex, SMTP_FROM must be an existing sender mailbox, usually equal to SMTP_USER.
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_FROM_NAME=MedTour

# S3-compatible storage in production, usually MinIO in Coolify.
# MINIO_ENDPOINT=http://minio:9000
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=medtour
# Alternative aliases are supported:
# S3_ENDPOINT=http://minio:9000
# S3_ACCESS_KEY_ID=
# S3_ACCESS_SECRET=
# S3_BUCKET=medtour
# S3_REGION=us-east-1

# Free consultations are enabled by default. Set to false only when paid
# consultations are re-enabled.
FREE_CONSULTATIONS=true

# Rate limits for auth endpoints. Raise these on load-test/demo days when many
# testers share one NAT/VPN IP. Keep RATE_LIMIT_TRUST_PROXY=true behind Coolify,
# Nginx, Cloudflare, or another reverse proxy that sends X-Forwarded-For.
RATE_LIMIT_TRUST_PROXY=true
AUTH_LOGIN_RATE_LIMIT_MAX=60
AUTH_LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_REGISTER_RATE_LIMIT_MAX=300
AUTH_REGISTER_RATE_LIMIT_WINDOW_MINUTES=60
AUTH_FORGOT_PASSWORD_RATE_LIMIT_MAX=20
AUTH_FORGOT_PASSWORD_RATE_LIMIT_WINDOW_MINUTES=60
CHECK_EMAIL_RATE_LIMIT_MAX=300
CHECK_EMAIL_RATE_LIMIT_WINDOW_MINUTES=15

# Set to true in production when paid consultation flow is enabled.
PAYMENTS_LIVE=false

# Temporary preview mode: allows PAYMENTS_LIVE=false on production domains.
# Do not enable this for real paid traffic.
ALLOW_TEST_PAYMENTS_IN_PRODUCTION=false

# Future native push sender config. Do not commit real secrets.
# Device tokens are collected through /api/device-tokens/register.
# FCM_PROJECT_ID=
# FCM_CLIENT_EMAIL=
# FCM_PRIVATE_KEY=
# APNS_TEAM_ID=
# APNS_KEY_ID=
# APNS_BUNDLE_ID=kz.nnmc.medtour
