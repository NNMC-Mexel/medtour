# MedTour frontend configuration
VITE_APP_NAME=MedTour

# Strapi backend (development)
VITE_API_URL=http://localhost:1340

# WebRTC signaling server (development)
VITE_SIGNALING_SERVER=http://localhost:1341

# Production URLs — override hardcoded fallbacks when deploying to a different domain
VITE_PRODUCTION_API_URL=https://medtourserver.nnmc.kz
VITE_PRODUCTION_SIGNALING_URL=https://medtourrtc.nnmc.kz
VITE_PRODUCTION_FRONTEND_HOSTS=medtour.nnmc.kz,www.medtour.nnmc.kz

# TURN server (WebRTC NAT traversal)
VITE_TURN_URL=turn:medtour.nnmc.kz:3478
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# ePay: set to "false" in production
VITE_EPAY_TEST=true

# Live payments: set to "true" in production
VITE_PAYMENTS_LIVE=false
