PORT=1341

# Frontend URL for CORS (development)
FRONTEND_URL=http://localhost:5173

# Comma-separated allowed origins in production (NODE_ENV=production)
CORS_ORIGINS=https://medtour.nnmc.kz,https://www.medtour.nnmc.kz,https://medtourserver.nnmc.kz,https://medtoursignaling.nnmc.kz

# Public URL of THIS signaling server (used as ePay callback base URL)
SIGNALING_PUBLIC_URL=https://medtoursignaling.nnmc.kz

# Payments live mode (must be true in production)
PAYMENTS_LIVE=false

# Temporary preview mode: allows PAYMENTS_LIVE=false on production domains.
# Do not enable this for real paid traffic.
ALLOW_TEST_PAYMENTS_IN_PRODUCTION=false

# ePay (Halyk Bank) Payment Gateway
EPAY_CLIENT_ID=
EPAY_CLIENT_SECRET=
EPAY_TERMINAL_ID=
EPAY_TEST=true

# QR Code API credentials (different terminal required)
EPAY_QR_CLIENT_ID=
EPAY_QR_CLIENT_SECRET=
EPAY_QR_TERMINAL_ID=

# Strapi API (server-side appointment creation after payment)
STRAPI_API_URL=http://localhost:1340
STRAPI_API_TOKEN=

# Optional. Required when running more than one signaling instance.
REDIS_URL=redis://redis:6379
